{
    "version": 2,
    "builds": [
        {
            "src": "apps/web/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://api.example.com/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/apps/web/$1"
        }
    ],
    "env": {
        "VITE_API_URL": "@api-url"
    }
}
