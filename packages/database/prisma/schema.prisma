generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String        @id @default(uuid())
  email             String        @unique
  passwordHash      String?
  name              String
  role              Role          @default(BUYER)
  authProvider      AuthProvider  @default(LOCAL)
  university        String?
  isVerified        Boolean       @default(false)
  avatar            String?
  bio               String?
  isSellerVerified  Boolean       @default(false)
  sellerVerifiedAt  DateTime?
  totalEarnings     Float         @default(0)
  availableBalance  Float         @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  notes             Note[]        @relation("SellerNotes")
  purchases         Purchase[]    @relation("BuyerPurchases")
  reviews           Review[]      @relation("UserReviews")
  transactions      Transaction[]
  cart              Cart?
  wishlist          Wishlist[]
  sentMessages      Message[]     @relation("SentMessages")
  conversations     ConversationParticipant[]
  payouts           SellerPayout[]
  noteViews         NoteView[]
  blogPosts         BlogPost[]
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

model Note {
  id            String     @id @default(uuid())
  title         String
  description   String
  price         Float
  fileUrl       String     // S3 url for full document
  previewUrl    String?    // S3 url for preview pages
  fileType      String     // PDF, DOCX, etc.
  fileSize      Int        // Size in bytes
  pageCount     Int?
  sellerId      String
  categoryId    String
  isApproved    Boolean    @default(false)
  isFeatured    Boolean    @default(false)
  viewCount     Int        @default(0)
  purchaseCount Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  seller        User       @relation("SellerNotes", fields: [sellerId], references: [id])
  category      Category   @relation(fields: [categoryId], references: [id])
  purchases     Purchase[]
  reviews       Review[]
  cartItems     CartItem[]
  wishlists     Wishlist[]
  tags          NoteTag[]
  views         NoteView[]
}

model Category {
  id         String   @id @default(uuid())
  university String
  course     String
  subject    String
  notes      Note[]

  @@unique([university, course, subject])
}

model Purchase {
  id             String          @id @default(uuid())
  buyerId        String
  noteId         String
  amount         Float
  discountAmount Float           @default(0)
  finalAmount    Float
  stripeChargeId String?
  status         PurchaseStatus  @default(PENDING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  buyer          User            @relation("BuyerPurchases", fields: [buyerId], references: [id])
  note           Note            @relation(fields: [noteId], references: [id])
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  userId    String
  noteId    String
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation("UserReviews", fields: [userId], references: [id])
  note      Note     @relation(fields: [noteId], references: [id])

  @@unique([userId, noteId]) // One review per user per note
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Float
  type      TxType
  status    TxStatus
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

enum TxType {
  PAYMENT
  WITHDRAWAL
}

enum TxStatus {
  PENDING
  COMPLETED
  FAILED
}

// Cart Models
model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  noteId    String
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())
  
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  
  @@unique([cartId, noteId])
}

// Wishlist Model
model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  noteId    String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  
  @@unique([userId, noteId])
}

// Tag System
model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  notes     NoteTag[]
  createdAt DateTime @default(now())
}

model NoteTag {
  id        String   @id @default(uuid())
  noteId    String
  tagId     String
  
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@unique([noteId, tagId])
}

// Messaging System
model Conversation {
  id           String                    @id @default(uuid())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
}

// Analytics
model NoteView {
  id        String   @id @default(uuid())
  noteId    String
  userId    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// Seller Payouts
model SellerPayout {
  id          String        @id @default(uuid())
  sellerId    String
  amount      Float
  status      PayoutStatus  @default(PENDING)
  method      String        // bank_transfer, paypal, etc.
  referenceId String?
  requestedAt DateTime      @default(now())
  processedAt DateTime?
  
  seller      User          @relation(fields: [sellerId], references: [id])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// Coupons
model Coupon {
  id             String    @id @default(uuid())
  code           String    @unique
  discountType   String    // percentage, fixed
  discountValue  Float
  minPurchase    Float     @default(0)
  maxUses        Int?
  usedCount      Int       @default(0)
  validFrom      DateTime
  validUntil     DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
}

// Blog Posts
model BlogPost {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  content     String
  excerpt     String?
  coverImage  String?
  authorId    String
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  author      User      @relation(fields: [authorId], references: [id])
}
